# Copy to terraform.tfvars (gitignored) and fill in.
# Secrets (bp_secret_key, ssh_public_key) live in secrets.auto.tfvars (also gitignored).
# scripts/up.sh generates both files from .env automatically.
#
# AWS CREDENTIALS are NEVER set here. The AWS provider uses the standard CLI chain:
#   - env vars (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN)
#   - ~/.aws/credentials / ~/.aws/config (named profile via AWS_PROFILE or aws_profile var)
#   - IAM role (EC2 / ECS / SSO)
# Run `aws configure` or `aws sso login --profile <name>` first.

demo              = "manufacturing"
region            = "us-east-1"
instance_type     = "t3.small"
admin_username    = "ubuntu"
resource_prefix   = "bpdemo"

# Optional — named profile from ~/.aws/credentials. Leave empty to use default chain.
# aws_profile     = "se-demo"

# Narrow to your workstation IP to avoid exposing SSH publicly:
# admin_source_cidr = "203.0.113.10/32"
admin_source_cidr = "0.0.0.0/0"

# ssh_public_key is typically sourced from ~/.ssh/id_rsa.pub or id_ed25519.pub.
# scripts/up.sh reads SSH_PUBLIC_KEY_PATH from .env and injects it.
# ssh_public_key = "ssh-ed25519 AAAA..."
